PORT=5000
DATABASE_URL=postgres://username:password@localhost:5432/dbname?xxx=xxx
SERVER_ADDRESS=:5000
ENVIRONMENT=development
GOOGLE_CLIENT_ID=your google client id
GOOGLE_CLIENT_SECRET=your google client secret
GOOGLE_REDIRECT_URL=url for google to redirect to after successful oauth
GITHUB_CLIENT_ID=your github client id
GITHUB_CLIENT_SECRET=github secret
GITHUB_REDIRECT_URL=url for github to redirect to after successful oauth
CLIENT_DASHBOARD=the client dashboard
STORAGE_SERVICE_ACCESS_KEY_ID=object storage key id
STORAGE_SERVICE_SECRET_ACCESS_KEY=object storage secret key
BUCKET_NAME=bucket name
STORAGE_SERVICE_ENDPOINT=endpoint for object storage
BUCKET_ROOT=the root of all files
DATA_GET_PATH=the url for accessing public assets
REDIS_ADDR=your redis endpoint
REDIS_PASSWORD=your redis password
CLIENT_LOGIN_URL=the url to redirect user to after successful oauth
